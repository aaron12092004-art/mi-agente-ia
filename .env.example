# ============================================
# CONFIGURACIÓN DEL AGENTE IA
# ============================================
# Copiá este archivo como ".env" y completá tus datos

# API KEY DE GROQ (gratis)
# Conseguila en: https://console.groq.com/ → API Keys → Create API Key
GROQ_API_KEY=tu_api_key_aqui

# PUERTO DEL SERVIDOR (default: 3000)
PORT=3000

# EMAIL PARA NOTIFICACIONES (opcional)
# Cuando escala a humano o se captura un lead, te avisa por email
NOTIFICATION_EMAIL=tu@email.com

# CONFIGURACIÓN DE EMAIL (para enviar notificaciones)
# Podés usar Gmail con una "contraseña de aplicación"
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu@gmail.com
SMTP_PASS=tu_contraseña_de_aplicacion

# WHATSAPP (opcional - requiere cuenta WhatsApp Business API)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=mi_token_secreto
